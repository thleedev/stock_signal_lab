<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- SMS 수신/읽기 -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- 인터넷 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- 부팅 시 자동 시작 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 알림 게시 (Foreground Service 알림) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />


    <!-- 키움증권 앱 실행을 위한 패키지 가시성 선언 (Android 11+) -->
    <queries>
        <package android:name="com.kiwoom.heromts" />
        <package android:name="com.kiwoom.smartopen" />
        <package android:name="com.kiwoom.hero4" />
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_notification"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight">

        <!-- 메인 Activity -->
        <activity
            android:name=".ui.StatusActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SMS BroadcastReceiver -->
        <receiver
            android:name=".service.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- 부팅 시 서비스 시작 -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- 오후 5시 signal_time 보정 트리거 -->
        <receiver
            android:name=".service.SignalTimeUpdateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dashboardstock.collector.UPDATE_SIGNAL_TIMES" />
            </intent-filter>
        </receiver>

        <!-- Notification Listener (푸시 감지) -->
        <service
            android:name=".service.NotificationListener"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Foreground Service (상시 실행) -->
        <service
            android:name=".service.CollectorForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- AccessibilityService (라씨매매 화면 스크래핑) -->
        <service
            android:name=".service.KiwoomAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

    </application>
</manifest>
